install.packages("igraph")
library(igraph)

edges <- data.frame(
from = c("A","A","B","C","C","D","E","F","G","H"),
to = c("B","C","D","D","E","E","F","G","H","A")
)

g <- graph_from_data_frame(edges)

plot(g,
     vertex.size = 30,
     vertex.color = "skyblue",
     vertex.label.color = "black",
     edge.arrow.size = 0.5,
     main = "Network Graph")
